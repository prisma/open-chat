// use prisma-next

model User {
  id            String    @id
  name          String
  email         String    @unique
  // NOTE: no @default(false) — prisma-next 0.13.0 drops falsy literal defaults
  // on emit (PN-CLI-4003 at db init). Better Auth always sets this on insert.
  emailVerified Boolean
  image         String?
  isAnonymous   Boolean?
  createdAt     DateTime  @default(now())
  updatedAt     temporal.updatedAt()
  sessions      Session[]
  accounts      Account[]
  chats         Chat[]
  usage         Usage[]
  // Effectively one-to-one (userId is unique on Billing); the SQL provider
  // only supports list back-references.
  billing       Billing[]
  creditGrants  CreditGrant[]
  contents      Content[]

  @@map("user")
}

// Ownership of stored content (full-resolution images in R2), so the
// /api/content proxy can restrict each object to the user whose chat it
// belongs to. Rows move with the user on guest -> account migration.
model Content {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("content")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt temporal.updatedAt()
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             temporal.updatedAt()

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  temporal.updatedAt()

  @@index([identifier])
  @@map("verification")
}

model Usage {
  id           String   @id
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  period       String
  // NOTE: no @default(0) — prisma-next 0.13.0 drops falsy literal defaults
  // on emit; the app always writes these columns explicitly.
  inputTokens  Int
  outputTokens Int
  costMicroUsd Int
  createdAt    DateTime @default(now())
  updatedAt    temporal.updatedAt()

  @@unique([userId, period])
  @@map("usage")
}

model Chat {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  model     String
  createdAt DateTime @default(now())
  updatedAt temporal.updatedAt()

  @@index([userId, updatedAt])
  @@map("chat")
}

// Per-user billing state. The credit balance itself is never stored — it is
// sum(CreditGrant.creditMicroUsd) minus lifetime Usage cost — so this row
// only tracks when the balance crossed zero, which starts the 30-day clock
// for the free top-up.
model Billing {
  id        String    @id
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  zeroAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt temporal.updatedAt()

  @@map("billing")
}

// Append-only credit ledger: the $2 signup grant, paid Stripe top-ups, and
// free $0.50 drips. Deterministic ids and the unique stripeSessionId make
// every grant idempotent.
model CreditGrant {
  id              String   @id
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind            String
  // NOTE: no @default(0) — prisma-next 0.13.0 drops falsy literal defaults
  // on emit; the app always writes these columns explicitly.
  creditMicroUsd  Int
  feeMicroUsd     Int
  paidMicroUsd    Int
  stripeSessionId String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       temporal.updatedAt()

  @@index([userId])
  @@map("credit_grant")
}
