# Copy this file to `.env`, then copy the active local URLs from:
#   bun run db:dev
#   DATABASE_URL=... bunx prisma dev ls
#
# Prisma Next requires PostgreSQL >= 17.
# Do not commit real secrets.
APP_ORIGIN=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
DATABASE_URL=postgres://postgres:postgres@localhost:51297/template1?sslmode=disable&connection_limit=10&connect_timeout=0&max_idle_connection_lifetime=0&pool_timeout=0&socket_timeout=0
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_APP_NAME=Open Chat Local
OPENROUTER_SITE_URL=http://localhost:3000
PORT=3000

# If set, Bun proxies durable reads/appends to this Prisma Streams server.
# Use the STREAM base URL from `prisma dev ls`, without `/v1/stream/...`.
STREAMS_URL=http://127.0.0.1:51299

# If STREAMS_URL is unset, the app starts @prisma/streams-local on this port.
STREAMS_PORT=51234
