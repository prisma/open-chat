# Copy this file to `.env`, then copy the active local URLs from:
#   bun run db:dev
#   DATABASE_URL=... bunx prisma dev ls
#
# Prisma Next requires PostgreSQL >= 17.
# Do not commit real secrets.
APP_ORIGIN=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
DATABASE_URL=postgres://postgres:postgres@localhost:51297/template1?sslmode=disable&connection_limit=10&connect_timeout=0&max_idle_connection_lifetime=0&pool_timeout=0&socket_timeout=0
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_APP_NAME=Open Chat Local
OPENROUTER_SITE_URL=http://localhost:3000
PORT=3000

# If set, Bun proxies durable reads/appends to this Prisma Streams server.
# Use the STREAM base URL from `prisma dev ls`, without `/v1/stream/...`.
STREAMS_URL=http://127.0.0.1:51299

# If STREAMS_URL is unset, the app starts @prisma/streams-local on this port.
STREAMS_PORT=51234

# Bearer key for a remote streams service (src/streams-app). Leave unset for
# local development; required when STREAMS_URL points at a deployed app.
# STREAMS_API_KEY=

# Stripe (optional). Without a secret key the top-up UI is hidden and the
# app runs free-credit only. The webhook secret enables /api/billing/webhook
# so payments credit even if the user never returns from checkout.
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Social sign-in (optional). Each provider appears on the auth screen only
# when its credentials are set.
# Callback URLs: <APP_ORIGIN>/api/auth/callback/github and /google
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# R2 / S3 snapshot persistence for the streams service (src/streams-app).
# The deployed instance's disk is ephemeral; with these set, the SQLite
# store is snapshotted to the bucket and rehydrated on a fresh instance.
# Leave unset for local development.
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_BUCKET=
# R2_SNAPSHOT_INTERVAL_MS=30000
