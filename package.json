{
  "name": "open-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server/index.ts",
    "start": "bun src/server/index.ts",
    "build": "bun build --target=bun --outdir=dist/server src/server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "prisma-next contract emit",
    "db:push": "prisma-next db update",
    "db:init": "prisma-next db init",
    "db:dev": "prisma dev --name open-chat --detach"
  },
  "dependencies": {
    "@openrouter/sdk": "0.12.79",
    "@prisma-next/postgres": "^0.13.0",
    "@prisma/streams-local": "0.1.10",
    "@tanstack/db": "0.6.8",
    "@tanstack/query-core": "5.101.0",
    "@tanstack/query-db-collection": "1.0.40",
    "@tanstack/react-db": "0.1.86",
    "better-auth": "1.6.16",
    "dotenv": "^17.4.2",
    "lucide-react": "0.476.0",
    "pg": "8.21.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260610.1",
    "@prisma/dev": "0.24.12",
    "@types/bun": "1.3.3",
    "@types/node": "^25.9.2",
    "@types/pg": "8.16.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "prisma": "7.8.0",
    "prisma-next": "^0.13.0",
    "typescript": "5.9.3"
  }
}
