{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "open-chat",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["--hot", "src/server/index.ts"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "open-chat-alt",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["--hot", "src/server/index.ts"],
      "port": 3210,
      "env": { "PORT": "3210", "APP_ORIGIN": "http://localhost:3210" },
      "autoPort": false
    },
    {
      "name": "open-chat-prod-sim",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["dist/server/start.js"],
      "port": 3201,
      "env": { "PORT": "3201" },
      "autoPort": false
    }
  ]
}
